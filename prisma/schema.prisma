generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// NOTE: SQLite does not support native enums via Prisma. We use plain strings
// with TypeScript unions (see src/lib/types.ts) instead.

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  passwordHash  String
  displayName   String
  isAdmin       Boolean  @default(false)
  balanceCents  Int      @default(300000000) // $3,000,000.00 starting bankroll
  createdAt     DateTime @default(now())
  bets          Bet[]
  favorites     Favorite[]
}

model Match {
  id              String   @id @default(cuid())
  sport           String   // "NFL" | "MLB" | "NBA"
  league          String
  homeTeam        String
  homeAbbr        String
  awayTeam        String
  awayAbbr        String
  startTime       DateTime
  status          String   @default("UPCOMING") // UPCOMING | LIVE | FINAL | CANCELED
  featured        Boolean  @default(false)
  homeScore       Int?
  awayScore       Int?

  spreadHome      Float?
  spreadHomeOdds  Int?
  spreadAwayOdds  Int?

  totalPoints     Float?
  totalOverOdds   Int?
  totalUnderOdds  Int?

  moneylineHome   Int?
  moneylineAway   Int?

  oddsDeltaBps    Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  selections      BetSelection[]
  favorites       Favorite[]
}

model Bet {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  stakeCents    Int
  payoutCents   Int
  combinedOdds  Int
  type          String   @default("SINGLE")  // SINGLE | PARLAY
  status        String   @default("PENDING") // PENDING | WON | LOST | VOID
  createdAt     DateTime @default(now())
  settledAt     DateTime?
  selections    BetSelection[]
}

model BetSelection {
  id            String  @id @default(cuid())
  betId         String
  bet           Bet     @relation(fields: [betId], references: [id], onDelete: Cascade)
  matchId       String
  match         Match   @relation(fields: [matchId], references: [id])
  market        String  // MONEYLINE | SPREAD | TOTAL
  pick          String  // HOME | AWAY | OVER | UNDER
  line          Float?
  americanOdds  Int
  status        String  @default("PENDING") // PENDING | WON | LOST | VOID
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  matchId   String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, matchId])
}
