# ─────────────────────────────────────────────────────────────
# Alpexa 일일 리포트 이메일 설정 — 이 파일을 복사해서 .env 를 만드세요:
#     cp .env.example .env
# 그런 다음 아래 값을 채우세요. .env 는 절대 git에 올라가지 않습니다(.gitignore).
# ─────────────────────────────────────────────────────────────

# 보내는 메일 서버 (Gmail이면 아래 그대로). 참고: "://gmail.com" 이 아니라 smtp.gmail.com 입니다.
EMAIL_HOST=smtp.gmail.com

# 발신용 이메일 주소 (리포트를 "보내는" 계정 — Gmail 권장)
EMAIL_USER=your-sender@gmail.com

# 이메일 "앱 비밀번호" (16자리). 일반 로그인 비번이 아닙니다! → 가이드 참고
EMAIL_PASS=xxxx xxxx xxxx xxxx

# 리포트를 "받아볼" 내 개인 이메일 주소 (여러 명이면 쉼표로: a@x.com,b@y.com)
EMAIL_TO=me@example.com
