# ─────────────────────────────────────────────────────────────
# Alpexa 일일 리포트 이메일 설정 — 이 파일을 복사해서 .env 를 만드세요:
#     cp .env.example .env
# 그런 다음 아래 값을 채우세요. .env 는 절대 git에 올라가지 않습니다(.gitignore).
# ─────────────────────────────────────────────────────────────

# 보내는 메일 서버 (Gmail이면 아래 그대로). 참고: "://gmail.com" 이 아니라 smtp.gmail.com 입니다.
EMAIL_HOST=smtp.gmail.com

# 발신용 이메일 주소 (리포트를 "보내는" 계정 — Gmail 권장)
EMAIL_USER=your-sender@gmail.com

# 이메일 "앱 비밀번호" (16자리). 일반 로그인 비번이 아닙니다! → 가이드 참고
EMAIL_PASS=xxxx xxxx xxxx xxxx

# 리포트를 "받아볼" 내 개인 이메일 주소 (여러 명이면 쉼표로: a@x.com,b@y.com)
EMAIL_TO=me@example.com

# ── 실데이터 연결 (Supabase) ──────────────────────────────────
# 이 2개가 있으면 어제 자 진짜 거래/배팅 데이터로 리포트를 만듭니다.
# 없으면 최근 생성된 샘플 리포트로 폴백합니다(개발/미리보기용).
# Supabase 대시보드 → Project Settings → API 에서 확인:
SUPABASE_URL=https://xxxxxxxx.supabase.co
# ⚠️ service_role 키 (전체 읽기 권한). 절대 외부 노출 금지 — anon 키 아님!
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key...
